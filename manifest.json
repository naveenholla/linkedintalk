{
  "manifest_version": 3,
  "name": "LinkedIn Speak Translator",
  "version": "1.0.0",
  "description": "Translate plain text to LinkedIn speak and back using linkedinspeak.com",
  "action": {
    "default_popup": "popup.html",
    "default_title": "LinkedIn Speak Translator"
  },
  "permissions": [],
  "host_permissions": [
    "https://linkedinspeak.com/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
